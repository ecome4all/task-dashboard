# Postgres connection string (Neon or Supabase free tier)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Port the server listens on
PORT=4000

# Where the frontend runs — needed so cookies/CORS work for login
FRONTEND_URL="http://localhost:5173"

# Long random string used to sign login sessions. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# Shared secret appended to the whapi.cloud webhook URL as ?secret=...
# (whapi.cloud has no built-in request signing, so this is what stops
# arbitrary internet requests from creating fake tasks)
WEBHOOK_SHARED_SECRET=""

# Used by the seed script to create the first login (see prisma/seed.ts)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Admin"

# whapi.cloud (group channel, transition period only)
WHAPI_API_KEY=""
WHAPI_BASE_URL="https://gate.whapi.cloud"

# Official WhatsApp Cloud API (added in Phase 3 - leave blank until then)
WHATSAPP_CLOUD_API_TOKEN=""
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
# Arbitrary string you choose; enter the same value when registering the
# webhook URL in the Meta App Dashboard so it can verify the endpoint
WHATSAPP_VERIFY_TOKEN=""
