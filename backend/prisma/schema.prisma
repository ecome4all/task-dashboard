generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// tenantId is unused while there's only one business on the system, but every
// row carries it from day one so multi-tenant resale later is a query filter,
// not a schema migration.
model Task {
  id          String    @id @default(cuid())
  tenantId    String    @default("default")
  source      String // "whatsapp_group" | "whatsapp_official"
  sourceRef   String // WhatsApp group id or phone number the task came from
  // Human-readable group name from whapi's webhook (chat_name), captured at
  // intake time so staff can recognize a group without reading its raw JID.
  // Null for official-channel (1:1) tasks, which have no group name.
  chatName    String?
  description String
  clientName  String?
  assignee    String?
  // listing | inventory_manage | fba | claims | inactive_blocked_product | no_pickup | ads | other
  // Nothing is auto-filled — same as assignee, this is picked manually during triage.
  taskType    String?
  // amazon | flipkart | meesho | other — also manually picked, not auto-detected from the message.
  marketplace String?
  // started | submitted | waiting_for_amazon | waiting_for_client | again_submitted | done
  status      String    @default("started")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  doneAt      DateTime?

  @@index([tenantId, status])
}

model Employee {
  id           String  @id @default(cuid())
  tenantId     String  @default("default")
  name         String
  email        String? @unique
  passwordHash String?
  role         String  @default("member") // "admin" | "manager" | "member"
  active       Boolean @default(true)
}

// A managed directory of clients, separate from Task.clientName (which is
// just whatever name comes in on the WhatsApp source and isn't linked here).
// Lets report-sends pick a saved phone number instead of retyping it.
model Client {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  name      String
  phone     String?
  // The WhatsApp group this client's tasks actually come from (whapi chat_id,
  // e.g. "919001524054-1380436383@g.us"), and its display name at the time it
  // was linked. Manually assigned by staff from the groups seen on incoming
  // tasks — never auto-matched. When set, this is the send target for
  // client updates / report links instead of `phone`.
  whatsappGroupId   String?
  whatsappGroupName String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// A task: message from a chat_id that isn't tied to any active Client yet —
// logged here instead of becoming a Task, so an unknown number can't spam
// the board, while staff can still see it, recognize it, and link it to a
// client (or add a new one) from the Clients tab. Once linked, that chat_id's
// future messages become real Tasks; existing rows here for it are just
// filtered out of the "unrecognized" view, not deleted.
model UnrecognizedMessage {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  source    String
  sourceRef String // chat_id
  chatName  String?
  text      String
  createdAt DateTime @default(now())

  @@index([tenantId, sourceRef])
}

// Admin-editable dropdown options for Task fields: "marketplace", "status",
// and "task_type". `value` is the stable machine value stored on Task rows
// (e.g. "amazon") and is never changed after creation, even if `label` is
// renamed later — existing tasks keep referencing it correctly either way.
// Deactivating an option removes it from the dropdown going forward without
// touching tasks that already used it. Employee role and the Employee/
// Assignee dropdown itself aren't here: role is tied to real permission code
// (an arbitrary new role would have no actual access behavior), and Assignee
// is already dynamic — it's just the live Employees list.
model ConfigOption {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  category  String // "marketplace" | "status" | "task_type"
  value     String
  label     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([tenantId, category, value])
}

// A saved link to a report the client owns and maintains themselves
// (e.g. a Google Sheet) — this app never reads/writes its contents,
// just stores the link and sends it to the client over WhatsApp.
model ReportLink {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  description String
  url         String
  createdBy   String
  createdAt   DateTime @default(now())
  lastSentAt  DateTime?
}
