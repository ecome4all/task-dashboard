generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// tenantId is unused while there's only one business on the system, but every
// row carries it from day one so multi-tenant resale later is a query filter,
// not a schema migration.
model Task {
  id          String    @id @default(cuid())
  tenantId    String    @default("default")
  source      String // "whatsapp_group" | "whatsapp_official"
  sourceRef   String // WhatsApp group id or phone number the task came from
  description String
  clientName  String?
  assignee    String?
  status      String    @default("new") // new | in_progress | done
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  doneAt      DateTime?

  @@index([tenantId, status])
}

model Employee {
  id           String  @id @default(cuid())
  tenantId     String  @default("default")
  name         String
  email        String? @unique
  passwordHash String?
  role         String  @default("member") // "admin" | "supervisor" | "member"
  active       Boolean @default(true)
}

// A saved link to a report the client owns and maintains themselves
// (e.g. a Google Sheet) — this app never reads/writes its contents,
// just stores the link and sends it to the client over WhatsApp.
model ReportLink {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  description String
  url         String
  createdBy   String
  createdAt   DateTime @default(now())
  lastSentAt  DateTime?
}
